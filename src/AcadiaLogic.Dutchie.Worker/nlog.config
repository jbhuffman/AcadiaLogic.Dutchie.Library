<?xml version="1.0" encoding="utf-8" ?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      autoReload="true"
      throwConfigExceptions="true">

  <targets>

    <!-- Console: Info and above, coloured by level -->
    <target xsi:type="ColoredConsole"
            name="console"
            layout="${date:format=HH\:mm\:ss} | ${pad:padding=5:inner=${level:uppercase=true}} | ${logger:shortName=true} | ${message} ${exception:format=tostring}">
      <highlight-row condition="level == LogLevel.Warn"  foregroundColor="Yellow"/>
      <highlight-row condition="level == LogLevel.Error" foregroundColor="Red"/>
      <highlight-row condition="level == LogLevel.Fatal" foregroundColor="Red" backgroundColor="White"/>
    </target>

    <!-- Rolling file: all levels, kept for 30 days / 100 MB per file -->
    <target xsi:type="File"
            name="file"
            fileName="${basedir}/logs/dutchie-worker.log"
            archiveFileName="${basedir}/logs/dutchie-worker.{#}.log"
            archiveNumbering="DateAndSequence"
            archiveDateFormat="yyyy-MM-dd"
            archiveAboveSize="104857600"
            maxArchiveFiles="30"
            layout="${longdate} | ${pad:padding=5:inner=${level:uppercase=true}} | ${logger} | ${message} ${exception:format=tostring}" />

    <!-- Errors-only file: permanent audit trail for failures and retry exhaustion -->
    <target xsi:type="File"
            name="errors"
            fileName="${basedir}/logs/dutchie-errors.log"
            archiveFileName="${basedir}/logs/dutchie-errors.{#}.log"
            archiveNumbering="DateAndSequence"
            archiveDateFormat="yyyy-MM-dd"
            archiveAboveSize="104857600"
            maxArchiveFiles="90"
            layout="${longdate} | ${pad:padding=5:inner=${level:uppercase=true}} | ${logger} | ${message} ${exception:format=tostring}" />

  </targets>

  <rules>
    <!-- Suppress noisy Microsoft framework internals below Warn -->
    <logger name="Microsoft.*"             maxlevel="Info" final="true" />
    <logger name="System.Net.Http.*"       maxlevel="Info" final="true" />

    <!-- Application logs -->
    <logger name="*" minlevel="Debug"  writeTo="file" />
    <logger name="*" minlevel="Info"   writeTo="console" />
    <logger name="*" minlevel="Error"  writeTo="errors" />
  </rules>

</nlog>
