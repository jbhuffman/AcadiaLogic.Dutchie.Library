# ── Dutchie POS API credentials ──────────────────────────────────────────────
# LocationKey  = Basic-Auth username  (from Dutchie back-office)
# IntegratorKey = Basic-Auth password (from Dutchie back-office)
DUTCHIE__LOCATIONKEY=
DUTCHIE__INTEGRATORKEY=

# ── Sage Intacct Web Services credentials ─────────────────────────────────────
# CompanyId    = Intacct company ID
# UserId       = Web Services user (dedicated integration user recommended)
# UserPassword = Web Services user password
# SenderId     = Sender ID assigned to this integration by Sage
# SenderPassword = Sender password
# EntityId     = Entity ID for multi-entity companies (leave blank for top-level)
# LocationId   = Intacct Location ID used to scope Platform App config rows
INTACCT__COMPANYID=
INTACCT__USERID=
INTACCT__USERPASSWORD=
INTACCT__SENDERID=
INTACCT__SENDERPASSWORD=
INTACCT__ENTITYID=
INTACCT__LOCATIONID=
